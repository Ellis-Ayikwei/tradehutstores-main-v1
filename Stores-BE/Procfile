release: python manage.py migrate --noinput && python manage.py collectstatic --noinput
web: gunicorn backend.wsgi:application --workers ${WEB_CONCURRENCY:-3} --timeout 60 --bind 0.0.0.0:${PORT:-8000} --access-logfile - --error-logfile -
worker: celery -A backend worker -l INFO --concurrency ${CELERY_CONCURRENCY:-2} --queues default,embeddings
