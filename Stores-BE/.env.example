# Stores-BE — copy to `.env` locally or set in Railway / your host.
# Comma-separated lists: no spaces around commas (unless part of a URL).

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Hostnames Django will serve (comma-separated).
# Include your LAN IP if the FE hits the API by IP (see ALLOWED_HOSTS_LAN when DEBUG=True).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.100.12
# Optional when DEBUG=True: extra IPs merged into ALLOWED_HOSTS (default 192.168.100.12).
# ALLOWED_HOSTS_LAN=192.168.100.12,192.168.1.50

# Railway may set this; if set, it is auto-appended to ALLOWED_HOSTS.
# RAILWAY_PUBLIC_DOMAIN=your-service.up.railway.app

# Browser Origins allowed for CSRF (scheme + host + port). Override defaults when deploying.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Prefer DATABASE_URL when present (Railway, Docker, etc.).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

DB_NAME=tradehut
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSL_REQUIRED=False

# ── DRF global rate limits (anon = unauthenticated IP; user = authenticated pk) ─
# One page load often issues many parallel GETs — keep bursts sane, tighten in prod if needed.
# REST_THROTTLE_ANON=200/min
# REST_THROTTLE_USER=2000/min

# ── CORS / frontend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.pages\.dev$,^https://.*\.tradehut\.com$
FRONTEND_URL=http://localhost:3000

# ── Cloudflare R2 (media storage via django-storages) ───────────────────────
USE_R2=False
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=tradehut-media
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_DOMAIN=images.example.com
# R2_OBJECT_PREFIX=media          # optional: keys become media/main_product_images/… so URLs match MEDIA_URL=/media/
# R2_PRIVATE_BUCKET=False

# ── Search / Celery / Redis ───────────────────────────────────────────────────
SEARCH_ENABLE_ES=False
SEARCH_ENABLE_EMBEDDINGS=False
SEARCH_ENABLE_SIGNALS=False
SEARCH_ES_INDEX=tradehut_products
# ES 8 + security: keep URL without user:pass; set password here only (must match ES).
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=
REDIS_URL=redis://localhost:6379/0
# FastAPI CLIP service only: tradehut_search/embedding_service (uvicorn, default port 8001).
# Example: http://127.0.0.1:8001  — NO path suffix; code calls /embed/image on this host.
# WRONG: http://localhost:8000/... (Django) → 404. Product images can still be R2 URLs;
# Django downloads them first, then POSTs bytes to this service.
EMBEDDING_SERVICE_URL=
CELERY_TASK_ALWAYS_EAGER=False

# ── Store / FX (catalog base currency; align FE NEXT_PUBLIC_TRADEHUT_STORE_BASE_CURRENCY) ──
TRADEHUT_STORE_BASE_CURRENCY=GHS
TRADEHUT_FX_FETCH_FRANKFURTER=True
TRADEHUT_FX_CACHE_SECONDS=14400

# ── Production hardening (read when DEBUG=False) ─────────────────────────────
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# ── Email (settings.py uses console backend in dev; switch to SMTP in prod) ─
# DEFAULT_FROM_EMAIL=noreply@example.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ── Authentication extras (optional; read in apps.authentication.views) ─────
# DEVICE_FINGERPRINT_SALT=
# DEVICE_TRUST_EXPIRY_DAYS=30
# DJANGO_SECRET_KEY=  # only if you wire debug tooling to this name; normally use SECRET_KEY above

# ── Third-party integrations (set when you use them) ─────────────────────────
# STRIPE_SECRET_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
