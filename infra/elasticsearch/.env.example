# Optional: copy to `.env` next to this compose file.
# If omitted, docker-compose uses a dev-only default (see docker-compose.yml).
# Production: use a long random value and keep it out of git.
ELASTIC_PASSWORD=use-a-32-char-random-string

# Optional: password for Elasticsearch user `kibana_system` (used by Kibana).
# If unset, the bootstrap service sets it to the same value as ELASTIC_PASSWORD.
# KIBANA_SYSTEM_PASSWORD=another-strong-secret
