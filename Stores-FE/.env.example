# Stores-FE environment template.
# In production these are set in the Cloudflare Pages dashboard
# (Settings → Environment Variables) — secrets via `wrangler pages secret put`.

# API base URL. axiosInstance.tsx and lib/searchClient.ts both read this.
NEXT_PUBLIC_API_URL=http://localhost:8000/tradehut/api/v1/

# ISO code catalog prices use until APIs expose per-row currency (must match BE TRADEHUT_STORE_BASE_CURRENCY).
NEXT_PUBLIC_TRADEHUT_STORE_BASE_CURRENCY=GHS

# Public R2 hostname for product imagery (set when USE_R2=True on the BE).
NEXT_PUBLIC_IMAGE_HOST=https://images.tradehut.com

# Optional: separate auth API host. If unset, lib/authAxiosInstance.tsx falls
# back to ${NEXT_PUBLIC_API_URL}/auth.
# NEXT_PUBLIC_AUTH_API_URL=
