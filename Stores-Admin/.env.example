# Stores-Admin environment template (Vite — read via import.meta.env).
#
# Local dev:    copy to `.env` and fill in. Vite picks them up at build time.
# Cloudflare:   set non-secrets in wrangler.toml [vars] and the Pages dashboard,
#               and any secrets via `wrangler pages secret put VAR_NAME`.

# API base URL. axiosInstance.tsx reads this. Must end with a slash.
VITE_API_URL=http://localhost:8000/tradehut/api/v1/

# ISO code admin pricing/dashboards default to. Must match BE TRADEHUT_STORE_BASE_CURRENCY
# and Stores-FE NEXT_PUBLIC_TRADEHUT_STORE_BASE_CURRENCY. Default GHS.
VITE_TRADEHUT_STORE_BASE_CURRENCY=GHS
